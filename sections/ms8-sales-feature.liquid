{% liquid
  assign featured_product = all_products['candidate-phone-stand-for-desk']
%}

{% if featured_product != blank %}
  <section class="ms8-sales-feature" aria-label="Featured verified product">
    <div class="ms8-sales-feature__media">
      {% if featured_product.featured_media %}
        {{
          featured_product.featured_media
          | image_url: width: 1100
          | image_tag:
            loading: 'eager',
            widths: '360, 540, 720, 900, 1100',
            sizes: '(max-width: 749px) 100vw, 48vw',
            class: 'ms8-sales-feature__image',
            alt: featured_product.title
        }}
      {% endif %}
    </div>

    <div class="ms8-sales-feature__content">
      <p class="ms8-sales-feature__eyebrow">Verified fast-sale pick</p>
      <h2>Adjustable phone stand, priced to move.</h2>
      <p>
        A compact desk, counter, and nightstand stand for hands-free video calls, streaming,
        recipes, and charging setups. This product is supplier-linked, media-verified, and
        priced through the store profit gate before publication.
      </p>

      <div class="ms8-sales-feature__proof" aria-label="Product checks">
        <span>Verified supplier cost</span>
        <span>Real product media</span>
        <span>Secure Shopify checkout</span>
      </div>

      <div class="ms8-sales-feature__buy">
        <strong>{{ featured_product.price | money }}</strong>
        <a class="ms8-sales-feature__button" href="{{ featured_product.url }}">Shop the verified pick</a>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Verified sales feature",
  "settings": [],
  "presets": [
    {
      "name": "Verified sales feature"
    }
  ]
}
{% endschema %}
