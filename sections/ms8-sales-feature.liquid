{% liquid
  assign featured_collection = collections['best-sellers'] | default: collections.all
  assign featured_product = featured_collection.products.first
%}

{% if featured_product != blank %}
  <section class="ms8-sales-feature" aria-label="Featured product">
    <div class="ms8-sales-feature__media">
      {% if featured_product.featured_media %}
        {{
          featured_product.featured_media
          | image_url: width: 1100
          | image_tag:
            loading: 'eager',
            widths: '360, 540, 720, 900, 1100',
            sizes: '(max-width: 749px) 100vw, 48vw',
            class: 'ms8-sales-feature__image',
            alt: featured_product.title
        }}
      {% endif %}
    </div>

      <div class="ms8-sales-feature__content">
      <p class="ms8-sales-feature__eyebrow">Featured right now</p>
      <h2>{{ featured_product.title }}</h2>
      <p>
        One of our most-loved finds, selected for everyday usefulness and clear value.
        View the product page for current options, delivery details, and checkout.
      </p>

      <div class="ms8-sales-feature__proof" aria-label="Product checks">
        <span>Clear pricing</span>
        <span>Curated for real life</span>
        <span>Secure Shopify checkout</span>
      </div>

      <div class="ms8-sales-feature__buy">
        <strong>{{ featured_product.price | money }}</strong>
        <a class="ms8-sales-feature__button" href="{{ featured_product.url }}">View product</a>
      </div>
    </div>
  </section>
{% endif %}

{% schema %}
{
  "name": "Verified sales feature",
  "settings": [],
  "presets": [
    {
      "name": "Verified sales feature"
    }
  ]
}
{% endschema %}
