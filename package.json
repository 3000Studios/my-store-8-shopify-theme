{
  "name": "my-store-8-shopify-theme",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "theme:pull": "shopify theme pull --store knkxfs-xd.myshopify.com --theme 181944025389 --nodelete",
    "theme:check": "shopify theme check",
    "theme:dev": "shopify theme dev --store knkxfs-xd.myshopify.com",
    "products:auto:dry-run": "node scripts/auto-product-publisher.mjs --once",
    "products:auto:publish-once": "node scripts/auto-product-publisher.mjs --once --publish",
    "products:auto:watch": "node scripts/auto-product-publisher.mjs",
    "products:auto:watch-publish": "node scripts/auto-product-publisher.mjs --publish",
    "products:bulk:dry-run": "node scripts/bulk-reactivate-products.mjs",
    "products:bulk:publish": "node scripts/bulk-reactivate-products.mjs --publish",
    "products:optimize:dry-run": "node scripts/optimize-active-products.mjs",
    "products:optimize:publish": "node scripts/optimize-active-products.mjs --publish",
    "products:zendrop:dry-run": "node scripts/zendrop-source-products.mjs",
    "products:zendrop:publish": "node scripts/zendrop-source-products.mjs --publish",
    "pages:upsert": "node scripts/upsert-store-pages.mjs",
    "collections:upsert": "node scripts/upsert-smart-collections.mjs",
    "bridge:status": "node scripts/shopify-bridge-status.mjs",
    "store:bootstrap": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/bootstrap-store-ops.ps1",
    "media:square": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-product-square.ps1",
    "media:vertical-ad": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-vertical-ad.ps1",
    "theme:push:preview": "shopify theme push --store knkxfs-xd.myshopify.com --unpublished",
    "theme:push:live": "shopify theme push --store knkxfs-xd.myshopify.com --theme 181944025389 --allow-live",
    "theme:push": "shopify theme push --store knkxfs-xd.myshopify.com --theme 181944025389 --allow-live"
  },
  "devDependencies": {
    "@shopify/cli": "4.4.0"
  }
}
