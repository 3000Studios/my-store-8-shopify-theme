{% liquid
  assign banner_title = collection.title | default: 'Shop'
  assign banner_description = collection.description | strip_html | strip
  assign topic_class = collection.handle | default: 'all'
  assign video_asset = 'bought-it-online-hero.mp4'
  assign eyebrow = 'Featured collection'
  assign cta_label = 'Shop now'
  assign cta_link = collection.url | default: '/collections/all'

  case collection.handle
    when 'outdoor-sports'
      assign eyebrow = 'Outdoor & sports'
      assign video_asset = 'sports-and-outdoors.mp4'
    when 'tech-accessories'
      assign eyebrow = 'Tech accessories'
      assign video_asset = 'tech-accessories.mp4'
    when 'home-living'
      assign eyebrow = 'Home & living'
      assign video_asset = 'home-and-living.mp4'
    when 'best-picks'
      assign eyebrow = 'Best picks'
      assign cta_label = 'See best picks'
    when 'all'
      assign eyebrow = 'Shop all practical finds'
      assign cta_label = 'Browse full catalog'
    when 'deals-under-25'
      assign eyebrow = 'Smart deals'
      assign cta_label = 'Grab deals under $25'
    when 'new-arrivals'
      assign eyebrow = 'Fresh arrivals'
      assign cta_label = 'See what\'s new'
  endcase
%}

<section class="ms8-collection-hero ms8-collection-hero--{{ topic_class | handle }}" aria-label="{{ banner_title | escape }} collection banner">
  <video class="ms8-collection-hero__video" autoplay muted loop playsinline preload="metadata">
    <source src="{{ video_asset | asset_url }}" type="video/mp4">
  </video>
  <div class="ms8-collection-hero__overlay"></div>
  <div class="ms8-collection-hero__inner">
    <p class="ms8-collection-hero__eyebrow">{{ eyebrow }}</p>
    <h1>{{ banner_title }}</h1>
    {% if banner_description != blank %}
      <p class="ms8-collection-hero__copy">{{ banner_description }}</p>
    {% else %}
      <p class="ms8-collection-hero__copy">Practical everyday essentials. Fair prices. No fake scarcity. Secure Shopify checkout.</p>
    {% endif %}
    <a href="{{ cta_link }}" class="ms8-collection-hero__cta button button--primary">{{ cta_label }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Collection video banner",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Collection video banner"
    }
  ]
}
{% endschema %}
